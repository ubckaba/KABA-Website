---
import "../styles/global.css";


---

<div id="nav-bar"
class="grid grid-cols-[auto_1fr_auto] w-full h-16 sticky top-0 z-50
gap-0 content-end
bg-tan border-b-2 border-black">
    <button id="kaba-logo"
    class="bg-navy-blue rounded-t-[20px] border-x-2 border-t-2 border-black w-50
    text-white
    justify-self-start py-2 mt-1">
        KABABAYAN
    </button>
    <div id="nav-spacer">
        <!-- Empty middle div for spacing -->
    </div>
    <div id="nav-buttons"
    class="flex justify-self-end text-center gap-0">
        <a id="home-button" href="/"
        class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-base
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            HOME
        </a>
        <a id="kabamilya-button" href="/kabamilya"
        class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-base
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABAMILYA
        </a>
        <a id="kaba-album-button" href="/kaba-album"
        class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-base
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABA ALBUM
        </a>
        <a id="kabazine-button" href="/kabazine"
        class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-base
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABAZINE
        </a>
        <a id="filotalks-button" href="/filo-talks"
        class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-base
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            FILOTALKS
        </a>
    </div>
</div>