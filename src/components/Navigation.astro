---
import "../styles/global.css";
---

<div class="grid grid-cols-[auto_1fr_auto] w-full h-16 sticky top-0 z-50
gap-0 content-end
bg-tan border-b-2 border-black">
    <button class="bg-navy-blue rounded-t-[20px] border-x-2 border-t-2 border-black w-50
    text-white
    justify-self-start py-2 mt-1">
        KABABAYAN
    </button>
    <div>
        <!-- Empty middle div for spacing -->
    </div>
    <div class="flex justify-self-end gap-0">
        <button class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-lg
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            HOME
        </button>
        <button class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-lg
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABAMILYA
        </button>
        <button class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-lg
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABA ALBUM
        </button>
        <button class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-lg
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            KABAZINE
        </button>
        <button class="bg-red border-x-2 border-t-2 border-black rounded-t-[20px] w-50
        text-black font-acme text-lg
        py-2 mt-3
        hover:mt-1 hover:bg-light-red transition-all duration-200">
            FILOTALKS
        </button>
    </div>
</div>