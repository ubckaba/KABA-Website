---
import '../styles/global.css';
import Image from 'astro:assets';

const id = Astro.props;
const position = Astro.props;
const year = Astro.props;
const major = Astro.props;
const headshot = Astro.props;
---

<div id="member-card"
class="grid grid-cols-1
gap-0
divide-y-2 divide-black">
    <div id="member-top"
    class="w-full h-13
    bg-navy-blue rounded-t-[20px] border-black border-t-2 border-x-2">

    </div>

    <div class="border-x-2 border-black
    w-full h-min aspect-4/5 overflow-hidden">
        <img src={Astro.props.headshot}
        class="w-full h-min object-cover"/>
    </div>

    <div id="member-bottom"
    class="bg-red rounded-b-[20px] border-black border-b-2 border-x-2
    w-full h-min grid grid-cols-1
    items-center-safe justify-center-safe py-2 px-4 gap-0
    font-acme">
        <a id="member-name"
        class="text-xl uppercase text-black">
                {Astro.props.id}
        </a>

        <a id="member-position"
        class="text-xl text-brown">
                {Astro.props.position}
        </a>

        <a id="member-year"
        class="text-lg text-brown">
                Year {Astro.props.year}
        </a>

        <a id="member-major"
        class="text-lg text-brown">
                {Astro.props.major}
        </a>
    </div>
</div>