---
import '../styles/global.css';
import MemberCard from './MemberCard.astro';
import { getCollection } from 'astro:content';

const { dept } = Astro.props;
const m: any[] = await getCollection(dept as any);
const members = m.sort((a, b) => a.data.seq.valueOf() - b.data.seq.valueOf());
---

<div id="card-container"
class="w-full h-min grid grid-cols-4
bg-tan border-1 md:border-2 border-black rounded-[20px]
px-2 lg:px-36 py-1 lg:py-10 gap-x-0 lg:gap-y-4 gap-y-2">
    {members.map(member => (
        <MemberCard id={member.data.id} position={member.data.position} year={member.data.year} major={member.data.major} headshot={member.data.headshot} />
    ))}
</div>