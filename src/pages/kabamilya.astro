---
import Layout from '../layouts/Layout.astro';
import CardContainer from '../components/CardContainer.astro';
import SectionBody from '../components/SectionBody.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PageTitle from '../components/PageTitle.astro';
import PageBody from '../components/PageBody.astro';
import { getEntry } from 'astro:content';

const presidential = await getEntry('kabamilya' as any, 'Presidential');
const finance = await getEntry('kabamilya' as any, 'Finance');
const internals = await getEntry('kabamilya' as any, 'Internals');
const externals = await getEntry('kabamilya' as any, 'Externals');
const academic = await getEntry('kabamilya' as any, 'Academic');
const stulife = await getEntry('kabamilya' as any, 'Student Life');
const communications = await getEntry('kabamilya' as any, 'Communications');
---

<Layout>
	<div class="xl:px-50 sm:px-4 px-0 lg:pt-24 pt-16 lg:pb-12 pb-8 space-y-2 lg:space-y-4">
		<PageTitle title="Kabamilya"/>
		<PageBody descrip="At UBC KABABAYAN, we are all one big PAMILYA /paˈmilja/, meaning FAMILY! Meet our KABAMILYA -- the executive members that make everything happen!"/>
	</div>

	<div class="xl:px-60 sm:px-8 px-2 lg:py-12 pb-8 lg:space-y-24 space-y-8">
		<!-- Page content goes here -->
		<div id="presidential"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={presidential.data.id}/>
			<SectionBody descrip={presidential.data.description}/>
			<CardContainer dept='presidential'/>
		</div>
		<div id="finance"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={finance.data.id}/>
			<SectionBody descrip={finance.data.description}/>
			<CardContainer dept='finance'/>
		</div>
		<div id="internals"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={internals.data.id}/>
			<SectionBody descrip={internals.data.description}/>
			<CardContainer dept='internals'/>
		</div>
		<div id="externals"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={externals.data.id}/>
			<SectionBody descrip={externals.data.description}/>
			<CardContainer dept='externals'/>
		</div>
		<div id="academic"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={academic.data.id}/>
			<SectionBody descrip={academic.data.description}/>
			<CardContainer dept='academic'/>
		</div>
		<div id="stulife"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={stulife.data.id}/>
			<SectionBody descrip={stulife.data.description}/>
			<CardContainer dept='stulife'/>
		</div>
		<div id="communications"
		class="lg:space-y-4 space-y-2">
			<SectionTitle title={communications.data.id}/>
			<SectionBody descrip={communications.data.description}/>
			<CardContainer dept='communications'/>
		</div>
	</div>
</Layout>
