---
import Layout from '../layouts/Layout.astro';
import GalleryCard from '../components/GalleryCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SectionBody from '../components/SectionBody.astro';
import PageBody from '../components/PageBody.astro';
import PageTitle from '../components/PageTitle.astro';
import { getCollection } from 'astro:content';

const kabaAlbum: any[] = await getCollection('kabaAlbum' as any)
const events = kabaAlbum.sort(
	(a, b) => b.data.id.valueOf() - a.data.id.valueOf()
);
---

<Layout>
	<div class="justify-center items-center grid grid-cols-1
	mx-40 my-25 gap-4">
		<PageTitle title="KABA ALBUM"/>
		<PageBody descrip="Browse photos from our previous events -- who knows, you might appear in a picture or two! All photo albums are located on Google Drive."/>
	</div>

	<div class="justify-center items-center grid grid-cols-1
	mx-50 my-25 gap-25">
		<!-- Page content goes here -->

		{events.map(event => (
			<div class="grid grid-cols-1
			gap-4">
				<SectionTitle title={event.data.title}/>
				<SectionBody descrip={event.data.description}/>
				<GalleryCard text="OPEN THE PHOTO ALBUM!" cover={event.data.cover} image1={event.data.image1} image2={event.data.image2} link={event.data.link}/>
			</div>
		))}

	</div>
</Layout>
